# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgres://admin:password@localhost:5432/zurfur

# JWT signing secret (any random string, e.g.: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret

# AT Protocol OAuth
OAUTH_CLIENT_ID=https://zurfur.app
OAUTH_REDIRECT_URI=http://localhost:5173/callback
OAUTH_PRIVATE_KEY=

# Optional (defaults shown)
# JWT_ACCESS_EXPIRY_SECS=900
# JWT_REFRESH_EXPIRY_SECS=2592000
