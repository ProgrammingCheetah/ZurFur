sequenceDiagram
    participant U as User (UI)
    participant B as Rust Backend (AppView)
    participant DB as Postgres (The Mirror)
    participant R as Identity Resolver
    participant PDS as User's PDS (The Truth)

    U->>B: Request Login (handle/DID)
    
    B->>DB: Get Session (did)
    DB-->>B: Session or None

    alt Session Exists
        alt Access Token Valid
            B-->>U: Session Success (Immediate)
        else Access Token Expired
            B->>PDS: DPoP Silent Refresh (refresh_token)
            alt Refresh Successful
                PDS-->>B: New Tokens
                B->>DB: Update Session
                B-->>U: Session Success
            else Refresh Failed (Revoked)
                B->>DB: Delete Session
                B-->>U: Prompt Full Login
            end
        end
    else No Session Found
        B->>R: Resolve Identity (Handle -> DID)
        R-->>B: Identity (DID + PDS URL)
        
        B->>PDS: Initiate PAR (Pushed Auth Request)
        PDS-->>B: request_uri
        
        B->>DB: Store Temp State (pkce, state, nonce)
        B-->>U: Redirect to PDS (auth_url)
        
        U->>PDS: User Approves Permissions
        PDS-->>U: Redirect to Callback (code, state)
        
        U->>B: GET /callback (code, state)
        B->>DB: Retrieve & Validate State
        
        B->>PDS: Exchange Code (DPoP + PKCE)
        PDS-->>B: Final Access/Refresh Tokens (sub = DID)
        
        B->>B: Verify token sub matches resolved DID
        B->>DB: Create Encrypted Session
        B-->>U: Login Complete
    end